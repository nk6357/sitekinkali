# SMTP Configuration for Email Sending
# Using Mailtrap.io for testing (replace with your SMTP service)

# For testing with Mailtrap.io:
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_SECURE=false
SMTP_USER=your_mailtrap_user
SMTP_PASSWORD=your_mailtrap_password
SMTP_FROM=noreply@sitekinkali.ru

# Admin email to receive orders
ADMIN_EMAIL=orders@sitekinkali.ru

# Server port
PORT=3000

# Alternative: Using Gmail (less secure app password required)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@sitekinkali.ru
